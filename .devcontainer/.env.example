# Dev Container Environment

# Tailscale
TS_AUTHKEY=tskey-auth-xxxxxxxxxxxx
TS_HOSTNAME=loomkin-dev
TS_NETWORK=tailxxxx.ts.net

# GitHub SSH keys
GITHUB_USERS=

# Database (optional - use DATABASE_URL directly)
DATABASE_URL=ecto://postgres:postgres@localhost:5432/loomkin_dev

# Ollama local LLM
# Default: http://localhost:11434
OLLAMA_HOST=http://localhost:11434

# vLLM local LLM
# Default: http://localhost:8000
VLLM_HOST=http://localhost:8000
