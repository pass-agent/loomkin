<div class="loom-home min-h-screen relative overflow-hidden flex items-center justify-center" style="background: var(--surface-0);">
  <%!-- Thread background --%>
  <svg class="absolute inset-0 w-full h-full" preserveAspectRatio="none" aria-hidden="true">
    <line x1="0%" y1="30%" x2="100%" y2="45%" stroke="var(--brand)" stroke-width="0.5" opacity="0.05" class="loom-thread-1" />
    <line x1="0%" y1="60%" x2="100%" y2="35%" stroke="var(--accent-amber)" stroke-width="0.5" opacity="0.04" class="loom-thread-2" />
    <line x1="0%" y1="75%" x2="100%" y2="55%" stroke="var(--accent-cyan)" stroke-width="0.3" opacity="0.03" class="loom-thread-3" />
  </svg>

  <div class="relative z-10 w-full max-w-sm px-5" style="animation: fadeUp 0.6s cubic-bezier(0.16, 1, 0.3, 1) both;">
    <%!-- Owl + wordmark --%>
    <div class="text-center mb-10">
      <svg width="48" height="48" viewBox="0 0 32 32" fill="none" class="mx-auto mb-4 drop-shadow-[0_0_16px_rgba(180,160,232,0.15)]">
        <path d="M16 3C9.5 3 5.5 7.5 5.5 13.5c0 3.5 1.5 6.5 3.5 8.5C11 24 13 26 16 26s5-2 7-4c2-2 3.5-5 3.5-8.5C26.5 7.5 22.5 3 16 3z" fill="var(--surface-1)" stroke="var(--brand)" stroke-width="1" />
        <path d="M11 5.5L9.5 2.5M21 5.5l1.5-3" stroke="var(--brand)" stroke-width="1.2" stroke-linecap="round" />
        <circle cx="12" cy="13" r="3.5" fill="var(--surface-0)" stroke="var(--accent-amber)" stroke-width="0.8" />
        <circle cx="12.3" cy="12.7" r="1.5" fill="var(--accent-amber)" />
        <circle cx="20" cy="13" r="3.5" fill="var(--surface-0)" stroke="var(--accent-amber)" stroke-width="0.8" />
        <circle cx="20.3" cy="12.7" r="1.5" fill="var(--accent-amber)" />
        <path d="M15 17l1 1.5 1-1.5" stroke="var(--accent-peach)" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" />
      </svg>
      <h1 class="text-2xl font-extralight tracking-tight" style="color: var(--text-primary);">
        l<span class="font-light" style="color: var(--text-secondary);">oo</span>m<span class="font-semibold" style="color: var(--brand);">kin</span>
      </h1>
      <p class="font-mono text-[10px] tracking-[0.15em] uppercase mt-2" style="color: var(--text-muted);">
        sign in to the workshop
      </p>
    </div>

    <%!-- Card --%>
    <div class="rounded-xl p-7 space-y-6" style="background: var(--surface-1); border: 1px solid var(--border-subtle);">
      <div
        :if={local_mail_adapter?()}
        class="rounded-lg p-3 flex items-start gap-2.5"
        style="background: var(--surface-2); border: 1px solid var(--border-subtle);"
      >
        <.icon name="hero-information-circle" class="size-4 shrink-0 mt-0.5" style="color: var(--accent-cyan);" />
        <div class="text-xs" style="color: var(--text-muted);">
          <p>Local mail adapter active.</p>
          <p class="mt-0.5">
            Check <.link href="/dev/mailbox" class="underline underline-offset-2" style="color: var(--text-brand);">the mailbox</.link>.
          </p>
        </div>
      </div>

      <%!-- Email magic link --%>
      <.form :let={f} for={@form} as={:user} id="login_form_magic" action={~p"/users/log-in"}>
        <div class="space-y-4">
          <div>
            <label for={f[:email].id} class="block text-[11px] font-mono uppercase tracking-wider mb-2" style="color: var(--text-muted);">
              Email
            </label>
            <input
              type="email"
              id={f[:email].id}
              name={f[:email].name}
              value={f[:email].value}
              readonly={!!@current_scope}
              autocomplete="username"
              spellcheck="false"
              required
              phx-mounted={JS.focus()}
              class="w-full px-4 py-3 rounded-lg text-sm border-0 outline-none focus:ring-1"
              style="background: var(--surface-2); color: var(--text-primary); --tw-ring-color: var(--brand);"
              placeholder="you@example.com"
            />
          </div>
          <button
            type="submit"
            class="w-full py-3 rounded-lg text-sm font-medium flex items-center justify-center gap-2 transition-all"
            style="background: var(--brand); color: var(--surface-0);"
          >
            Sign in with email
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
            </svg>
          </button>
        </div>
      </.form>

      <%!-- Divider --%>
      <div class="flex items-center gap-3">
        <div class="flex-1 h-px" style="background: var(--border-subtle);" />
        <span class="text-[10px] font-mono" style="color: var(--text-muted);">or use password</span>
        <div class="flex-1 h-px" style="background: var(--border-subtle);" />
      </div>

      <%!-- Password form --%>
      <.form :let={f} for={@form} as={:user} id="login_form_password" action={~p"/users/log-in"}>
        <div class="space-y-4">
          <div>
            <label for="password-email" class="block text-[11px] font-mono uppercase tracking-wider mb-2" style="color: var(--text-muted);">
              Email
            </label>
            <input
              type="email"
              id="password-email"
              name={f[:email].name}
              value={f[:email].value}
              readonly={!!@current_scope}
              autocomplete="username"
              spellcheck="false"
              required
              class="w-full px-4 py-3 rounded-lg text-sm border-0 outline-none focus:ring-1"
              style="background: var(--surface-2); color: var(--text-primary); --tw-ring-color: var(--brand);"
              placeholder="you@example.com"
            />
          </div>
          <div>
            <label for={f[:password].id} class="block text-[11px] font-mono uppercase tracking-wider mb-2" style="color: var(--text-muted);">
              Password
            </label>
            <input
              type="password"
              id={f[:password].id}
              name={f[:password].name}
              autocomplete="current-password"
              spellcheck="false"
              class="w-full px-4 py-3 rounded-lg text-sm border-0 outline-none focus:ring-1"
              style="background: var(--surface-2); color: var(--text-primary); --tw-ring-color: var(--brand);"
              placeholder="••••••••"
            />
          </div>
          <div class="flex gap-2">
            <button
              type="submit"
              name={@form[:remember_me].name}
              value="true"
              class="flex-1 py-3 rounded-lg text-sm font-medium transition-all"
              style="background: var(--brand); color: var(--surface-0);"
            >
              Stay signed in
            </button>
            <button
              type="submit"
              class="flex-1 py-3 rounded-lg text-sm font-medium transition-all"
              style="background: var(--surface-2); color: var(--text-secondary); border: 1px solid var(--border-subtle);"
            >
              One-time
            </button>
          </div>
        </div>
      </.form>
    </div>

    <%!-- Footer --%>
    <p class="text-center mt-8 text-xs" style="color: var(--text-muted);">
      No account yet?
      <.link
        navigate={~p"/users/register"}
        class="font-medium transition-colors"
        style="color: var(--text-brand);"
      >
        Join the workshop
      </.link>
    </p>
  </div>
</div>
